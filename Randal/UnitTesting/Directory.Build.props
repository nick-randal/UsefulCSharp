        <PackageProjectUrl>https://github.com/nick-randal/UsefulCSharp/blob/master/Randal/GwtUnit.XUnit</PackageProjectUrl>
        <PackageTags>UnitTest GWT XUnit</PackageTags>
    </PropertyGroup>
</Project>