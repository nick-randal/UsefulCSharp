<Project>
    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0;</TargetFrameworks>
        <Version>2.0.0</Version>

        <Title>Given-When-Then Unit Testing</Title>
        <LangVersion>12</LangVersion>
        <Nullable>enable</Nullable>
